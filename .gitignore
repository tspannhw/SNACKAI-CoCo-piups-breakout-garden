# =============================================================================
# PiUPS IoT Sensor App - .gitignore
# Production-safe: excludes all secrets, credentials, and sensitive data
# =============================================================================

# Python bytecode and packaging
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
AGENDA.md

# Virtual environments
venv/
.venv/
env/
ENV/

# IDE and editors
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# Secrets and credentials - NEVER commit these
snowflake_config.json
*.p8
*.pem
*.key
*.der
connections.toml
.env
.env.*
!.env.example

# Snowflake
snowsql_config
.snowflake/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
*.log
logs/
*.out

# Test artifacts
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.tox/
.nox/
junit.xml
test-results/

# SGP30 baseline cache (runtime state)
sgp30_baseline.json

# Raspberry Pi specific
*.img
*.img.gz
*.img.xz

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.orig

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Distribution / packaging
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# mypy / type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Streamlit
.streamlit/secrets.toml

# OLED / Luma
luma_cache/

# Tar archives (dev artifacts)
*.tar
*.tar.gz
*.zip
